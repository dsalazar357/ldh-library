generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id       Int     @id @default(autoincrement()) 
  email    String  @unique
  username String?
  password String
  degree   Int
  admin    Boolean @default(false)
  rituals  Ritual[]
} 

model Ritual { 
  id        Int     @id @default(autoincrement()) 
  title     String
  degree  Int
  url   String
  country String 
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id]) 
} 
